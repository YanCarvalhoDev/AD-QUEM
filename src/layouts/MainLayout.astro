---
import Header from '../components/Header';
import Footer from '../components/Footer';
import WhatsAppButton from '../components/WhatsAppButton';
import ProgressIndicator from '../components/ProgressIndicator';
import '../styles/global.css';

interface Props {
  title?: string;
  isDarkPage?: boolean;
  className?: string;
}

const { 
  title = "Sites para Advogados de Alto Padrão | Engenharia Digital AD QUEM", 
  isDarkPage = true, 
  className = "bg-teal-deep" 
} = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <link 
      rel="preload" 
      href="/fonts/inter-v20-latin-regular.woff2" 
      as="font" 
      type="font/woff2" 
      crossorigin 
    />
    <link 
      rel="preload" 
      href="/fonts/instrument-serif-v5-latin-regular.woff2" 
      as="font" 
      type="font/woff2" 
      crossorigin 
    />
    
    <title>Sites para Advogados de Alto Padrão | AD QUEM</title>
    <meta name="description" content="Engenharia de software de elite para bancas jurídicas boutique e o 1% do mercado brasileiro. Soluções digitais customizadas para alta performance." />
    <meta name="keywords" content="engenharia de software jurídico, arquiteto digital, tecnologia para advogados, automação jurídica, software sob medida, bancas boutique" />
    <link rel="canonical" href={Astro.url.href} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content="Projetamos sites de alto padrão para advogados que buscam autoridade inquestionável, performance de elite e conformidade total com a OAB." />
    <meta property="og:image" content="/AQ_logo_g.png" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url.href} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content="Projetamos sites de alto padrão para advogados que buscam autoridade inquestionável, performance de elite e conformidade total com a OAB." />
    <meta property="twitter:image" content="/AQ_logo_g.png" />

    <!-- Schema.org for Google -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "ProfessionalService",
        "name": "AdQuem,
        "description": "Projetamos sites de alto padrão para advogados que buscam autoridade inquestionável, performance de elite e conformidade total com a OAB.",
        "image": "/AQ_logo_g.png",
        "url": "https://www.adquem.com.br",
        "priceRange": "R$ 2.000,00+",
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": "-23.5505",
          "longitude": "-46.6333"
        },
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "São Paulo",
          "addressRegion": "SP",
          "addressCountry": "BR"
        },
        "areaServed": [
          {
            "@type": "Country",
            "name": "Brasil"
          },
          {
            "@type": "City",
            "name": "São Paulo",
            "description": "Centro estratégico de atendimento para bancas de alto padrão."
          }
        ],
        "openingHoursSpecification": {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": [
            "Monday",
            "Tuesday",
            "Wednesday",
            "Thursday",
            "Friday",
            "Saturday",
            "Sunday"
          ],
          "opens": "08:00",
          "closes": "20:00"
        },
        "hasOfferCatalog": {
          "@type": "OfferCatalog",
          "name": "Engenharia de Ativos Jurídicos",
          "itemListElement": [
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Arquitetura de Prestígio e Blindagem Digital",
                "description": "Desenvolvimento nativo com conformidade rigorosa ao Provimento 205/2021 da OAB e LGPD."
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Performance de Alta Disponibilidade",
                "description": "Infraestrutura de elite com carregamento instantâneo para garantir a retenção de clientes de alto ticket."
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Inteligência de Posicionamento e SEO",
                "description": "Dominância em buscas orgânicas para termos jurídicos de alta conversão e relevância estratégica."
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Design Institucional de Autoridade",
                "description": "Interfaces projetadas para transmitir solidez, tradição e o rigor técnico das bancas líderes de mercado."
              }
            }
          ]
        }
      }
    </script>
  </head>
  <body class={`min-h-screen selection:bg-gold-pale selection:text-teal-deep ${className}`}>
    <ProgressIndicator client:idle />
    
    <Header isDarkPage={isDarkPage} client:idle />
    
    <main>
      <slot />
    </main>

    <Footer client:visible />
    <!-- <WhatsAppButton client:visible /> -->
  </body>
</html>

<style is:global>
  :root {
    --accent: #C0B283;
  }
</style>
